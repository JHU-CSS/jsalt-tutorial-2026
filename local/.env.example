# Copy this file to .env and fill in your key:  cp .env.example .env
# Get a free key at https://console.groq.com/keys
# Do NOT commit your real .env — only this example file.
GROQ_API_KEY=gsk_your_key_here

# Optional — local LLM backup (used automatically if Groq fails or the key is blank).
# Start a server with ./run_ollama.sh (Mac/any) or ./run_vllm.sh (Linux+GPU), then
# set these to match it. Uncomment ONE pair:
#
# Ollama (run_ollama.sh):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:3b
#
# vLLM (run_vllm.sh):
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
